# ─────────────────────────────────────────────────────────
# 안심식품 검색기 환경 변수 템플릿
# 이 파일을 .env로 복사한 뒤 실제 값을 채워주세요.
# ─────────────────────────────────────────────────────────

# 식약처 OpenAPI 인증키
# 발급처: 공공데이터포털(data.go.kr) 또는 식품안전나라(foodsafetykorea.go.kr)
# 개발계정은 신청 즉시 자동 승인됩니다.
FOODSAFETY_API_KEY=your_api_key_here

# Discord 웹훅 URL (동기화 실패 시 즉시 알림)
# 채널 설정 → 웹훅 → 새 웹훅 → URL 복사
# 비워두면 Discord 알림 없이 로그 파일에만 기록됩니다.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# 백엔드 서버 포트 (기본: 3001)
PORT=3001

# 동기화 스케줄 — cron 형식 (기본: 매일 04:00)
SYNC_CRON=0 4 * * *
